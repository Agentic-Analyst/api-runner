# Environment variables for API Runner
# Copy this file to .env and fill in your actual API keys

# Backend Docker image configuration
BACKEND_IMAGE=stock-analyst:latest
DATA_VOLUME=stockdata

# API Keys - REQUIRED for the stock analyst backend to work
# Get your SERPAPI key from: https://serpapi.com/
SERPAPI_API_KEY=paste_your_serpapi_key_here

# Get your OpenAI key from: https://platform.openai.com/api-keys
# Should start with 'sk-'
OPENAI_API_KEY=sk-paste_your_openai_key_here

# Optional: Override default port
# PORT=8080
